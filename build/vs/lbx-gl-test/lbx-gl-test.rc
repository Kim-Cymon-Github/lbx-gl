// lbx-gl-test 버전 리소스 (Windows VERSIONINFO)
#define LBX_MODULE_NAME "lbx-gl-test"
#define LBX_IS_APP
#include <windows.h>
#include "../../../src/version.txt"
#include "../../../lib/lbx/include/lbx_version.h"

#ifdef _DEBUG
#define LBX_VER_FILEFLAGS VS_FF_DEBUG
#else
#define LBX_VER_FILEFLAGS 0x0L
#endif

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    VERSION_MAJOR,VERSION_MINOR,VERSION_PATCH,BUILD_NUMBER
 PRODUCTVERSION VERSION_MAJOR,VERSION_MINOR,VERSION_PATCH,BUILD_NUMBER
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
 FILEFLAGS      LBX_VER_FILEFLAGS
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       LBX_FILE_TYPE
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      LBX_COMPANY_NAME
            VALUE "FileDescription",  LBX_FILE_DESCRIPTION
            VALUE "FileVersion",      LBX_VER_STR
            VALUE "InternalName",     LBX_INTERNAL_NAME
            VALUE "OriginalFilename", LBX_INTERNAL_NAME
            VALUE "ProductName",      LBX_PRODUCT_NAME
            VALUE "ProductVersion",   LBX_VER_STR
            VALUE "LegalCopyright",   LBX_LEGAL_COPYRIGHT
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
